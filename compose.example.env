# === User settings: edit before first run ===
# Primary Outlook mailbox. account-db creates plus aliases from this address.
# outlook-imap-service uses Microsoft device flow and persists token automatically.
OUTLOOK_EMAIL=

# Proxy used by browser-reg during account registration.
REGISTER_PROXY_URL=socks5://host.docker.internal:10813

# GoPay account and proxy used by gopay-payment.
GOPAY_COUNTRY_CODE=62
GOPAY_PHONE_NUMBER=
GOPAY_PIN=
GOPAY_PROXY_URL=socks5://host.docker.internal:10813


# === Optional host ports: change only when local ports conflict ===
DASHBOARD_PORT=8080
GOPAY_WEBHOOK_PORT=8081
POSTGRES_PORT=5432
TEMPORAL_PORT=7233
BROWSER_REG_GRPC_PORT=50050
ACCOUNT_DB_GRPC_PORT=50052
OUTLOOK_GRPC_PORT=50053
GOPAY_GRPC_PORT=50054
ORCHESTRATOR_GRPC_PORT=50055


# === Stable defaults: normally do not edit ===
# Outlook token storage inside outlook-imap-service.
TOKEN_DIR=tokens
OUTLOOK_ALIAS_RANDOM_LENGTH=6

# Core database.
POSTGRES_USER=nb_register
POSTGRES_PASSWORD=nb_register
POSTGRES_DB=nb_register

# Temporal persistence databases and worker routing.
TEMPORAL_DB=temporal
TEMPORAL_VISIBILITY_DB=temporal_visibility
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=nb-register-orchestrator

# Internal service addresses used by orchestrator.
PAYMENT_ADDR=gopay-payment:50051
OTP_ADDR=gopay-payment:50051

# GoPay service-side OTP wait config.
GOPAY_OTP_SERVICE_ADDR=gopay-payment:50051
GOPAY_OTP_TIMEOUT_SECONDS=60
