# Core database
POSTGRES_USER=nb_register
POSTGRES_PASSWORD=nb_register
POSTGRES_DB=nb_register

# Temporal persistence databases created by temporalio/auto-setup
TEMPORAL_DB=temporal
TEMPORAL_VISIBILITY_DB=temporal_visibility
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=nb-register-orchestrator

# External services
PAYMENT_ADDR=gopay-payment:50051
OTP_ADDR=gopay-payment:50051

# GoPay payment runtime parameters.
# These are container/service config, not gRPC request parameters.
GOPAY_COUNTRY_CODE=62
GOPAY_PHONE_NUMBER=
GOPAY_PIN=
GOPAY_OTP_SERVICE_ADDR=gopay-payment:50051
GOPAY_OTP_TIMEOUT_SECONDS=60
GOPAY_PROXY_URL=socks5://host.docker.internal:10813
GOPAY_GRPC_PORT=50054
GOPAY_WEBHOOK_PORT=8081
GOPAY_OTP_WEBHOOK_TOKEN=

# Register browser proxy
REGISTER_PROXY_URL=socks5://host.docker.internal:10813

# Outlook split mailbox.
# OUTLOOK_EMAIL is the primary mailbox used by account-db to create plus aliases.
# TOKEN_DIR is mounted into outlook-imap-service; the service stores
# ${TOKEN_DIR}/outlook_refresh_token there. If the token file is missing,
# empty, expired, or revoked, outlook-imap-service automatically starts
# Microsoft device flow and prints the login code in container logs.
OUTLOOK_EMAIL=
TOKEN_DIR=tokens
OUTLOOK_ALIAS_RANDOM_LENGTH=6

# Host ports
POSTGRES_PORT=5432
TEMPORAL_PORT=7233
OUTLOOK_GRPC_PORT=50053
ACCOUNT_DB_GRPC_PORT=50052
ORCHESTRATOR_GRPC_PORT=50055
BROWSER_REG_GRPC_PORT=50050
DASHBOARD_PORT=8080
